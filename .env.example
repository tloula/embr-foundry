# Which backend to use: "completions" (default) or "agent" (future, not implemented).
CHAT_BACKEND=completions

# --- Completions backend (azure-ai-inference) ---
# Endpoint shapes accepted (embr injects one of these from the bound deployment):
#   <resource>.services.ai.azure.com/openai/v1   OpenAI-compatible route (preferred)
#   <resource>.services.ai.azure.com/models      unified models inference route
# Do NOT use the Foundry project endpoint (.../api/projects/<name>) here -- that
# belongs to the future agent backend (SUPPORT_AI_ENDPOINT) and fails with
# "(BadRequest) API version not supported".
CHAT_AI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
CHAT_AI_API_KEY=your-api-key
CHAT_AI_MODEL=gpt-4o-mini
# Optional. Override the API version. Unnecessary for normal use: the backend
# auto-selects api-version=preview for /openai/v1 endpoints and the SDK default
# for /models. e.g. 2024-08-01-preview
# CHAT_AI_API_VERSION=2024-08-01-preview

# --- Embeddings (azure-ai-inference EmbeddingsClient) ---
# Same endpoint shapes as CHAT_AI_ENDPOINT. The backend routes automatically:
#   /openai/v1                       used as-is, deployment sent in the body
#   /openai/deployments/<name>       used as-is, deployment in the path
#   /models (or bare resource base)  derived to /openai/deployments/<EMBED_AI_MODEL>
# (AOAI embedding deployments are not served by the unified /models route.)
EMBED_AI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
EMBED_AI_API_KEY=your-api-key
EMBED_AI_MODEL=text-embedding-3-small
# Optional API version override (unnecessary; preview is auto-selected for v1).
# EMBED_AI_API_VERSION=2024-08-01-preview

# --- Agent backend (azure-ai-projects, FUTURE / not implemented yet) ---
# Reserved so the platform can inject these now. The AgentBackend is a stub.
# SUPPORT_AI_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
# SUPPORT_AI_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
# SUPPORT_AI_AGENT_ID=asst_xxxxxxxxxxxxxxxx
