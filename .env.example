# Which backend to use: "completions" (default) or "agent" (future, not implemented).
CHAT_BACKEND=completions

# --- Completions backend (azure-ai-inference) ---
# IMPORTANT: this must be the resource's *models inference* endpoint ending in
# "/models" -- NOT the Foundry project endpoint (.../api/projects/<name>).
# Pointing ChatCompletionsClient at the project endpoint fails with
# "(BadRequest) API version not supported". The project endpoint belongs to the
# future agent backend below (SUPPORT_AI_ENDPOINT).
CHAT_AI_ENDPOINT=https://your-resource.services.ai.azure.com/models
CHAT_AI_API_KEY=your-api-key
CHAT_AI_MODEL=gpt-4o-mini
# Optional. Override the SDK's default API version. Usually unnecessary for the
# /models route (the default 2024-05-01-preview works). e.g. 2024-08-01-preview
# CHAT_AI_API_VERSION=2024-08-01-preview

# --- Embeddings (azure-ai-inference EmbeddingsClient) ---
# Same /models inference endpoint rule as CHAT_AI_ENDPOINT above. Used by the
# "Text embeddings" panel to prove an embedding model + its env injection work.
EMBED_AI_ENDPOINT=https://your-resource.services.ai.azure.com/models
EMBED_AI_API_KEY=your-api-key
EMBED_AI_MODEL=text-embedding-3-small
# Optional API version override (usually unnecessary for the /models route).
# EMBED_AI_API_VERSION=2024-08-01-preview

# --- Agent backend (azure-ai-projects, FUTURE / not implemented yet) ---
# Reserved so the platform can inject these now. The AgentBackend is a stub.
# SUPPORT_AI_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
# SUPPORT_AI_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
# SUPPORT_AI_AGENT_ID=asst_xxxxxxxxxxxxxxxx
